# CoT Surgeon — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── OpenRouter API (required for real LLM, optional for mock/demo) ─────────────
# Sign up at https://openrouter.ai to get a free key.
OPENROUTER_API_KEY=

# Base URL for the OpenRouter API (rarely needs changing)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model to use via OpenRouter. See https://openrouter.ai/models for full list.
# Default: mistralai/mistral-small-2603 (fast, capable, 262K context)
# Other good choices:
#   openai/gpt-5.4-nano     — ultra-fast, 400K context
#   openai/gpt-5.4-mini     — balanced speed/quality
#   z-ai/glm-5-turbo        — 202K context
#   minimax/minimax-m2.7    — 204K context
#   reka/reka-edge          — 16K context, very fast
#   openai/gpt-5.4          — premium quality, 1M context
#   x-ai/grok-4.20-beta     — premium quality, 2M context
OPENROUTER_MODEL=mistralai/mistral-small-2603

# ── LLM generation parameters ────────────────────────────────────────────────
# Maximum tokens to generate per LLM call
MAX_TOKENS=1024

# Sampling temperature (0.0 = deterministic, 1.0 = creative)
TEMPERATURE=0.7

# Number of reasoning steps to generate (2–7, default: 3)
COT_STEPS=3

# ── Retry logic ───────────────────────────────────────────────────────────────
# Maximum number of retries for failed OpenRouter API calls
MAX_RETRIES=3

# Initial delay in seconds between retries (doubles each attempt: 1s, 2s, 4s…)
RETRY_DELAY=1.0

# ── Confidence scoring ────────────────────────────────────────────────────────
# Nodes with confidence below this threshold are flagged in the UI
CONFIDENCE_THRESHOLD=0.7

# ── Undo history ──────────────────────────────────────────────────────────────
# Maximum number of undo snapshots to keep per graph session
MAX_HISTORY=20

# ── Local inference via llama.cpp (optional) ─────────────────────────────────
# Set LOCAL_MODE=true and point LLAMA_MODEL_PATH to a GGUF file to run offline.
LOCAL_MODE=false

# Absolute path to a GGUF model file (e.g. mistral-7b-instruct-v0.2.Q4_K_M.gguf)
LLAMA_MODEL_PATH=

# llama.cpp context window size
LLAMA_CTX_SIZE=2048

# Number of CPU threads for llama.cpp inference
LLAMA_THREADS=4

# ── Demo script settings ──────────────────────────────────────────────────────
# Override the default prompts used in demo.py
DEMO_PROMPT_1=Explain why the sky is blue
DEMO_PROMPT_2=What is 15%% of 240?

# Directory where demo.py saves output files (default: outputs/)
OUTPUTS_DIR=outputs

# ── Streamlit app settings ────────────────────────────────────────────────────
# Public URL of the deployed app (used for OpenRouter HTTP-Referer header)
APP_URL=https://github.com/dakshjain-1616/cot-surgeon

# Streamlit server port (default: 8501)
STREAMLIT_SERVER_PORT=8501

# Streamlit server host
STREAMLIT_SERVER_ADDRESS=localhost
